<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Technical fields: always updated on install/upgrade -->
    <record id="payment_provider_mpesa" model="payment.provider">
        <field name="name">M-Pesa</field>
        <field name="code">mpesa_daraja</field>
        <field name="module_id" ref="base.module_payment_mpesa_daraja"/>
        <field name="image_128" type="base64" file="payment_mpesa_daraja/static/description/icon.png"/>
        <field name="allow_tokenization" eval="False"/>
        <field name="support_refund">none</field>
        <field name="support_manual_capture">none</field>
        <field name="inline_form_view_id" ref="payment_mpesa_daraja.mpesa_inline_form"/>
        <field name="payment_method_ids"
               eval="[Command.set([ref('payment_mpesa_daraja.payment_method_mpesa')])]"/>
    </record>

    <!-- noupdate: protect user-configured fields from being reset on upgrade -->
    <data noupdate="1">
        <record id="payment_provider_mpesa" model="payment.provider">
            <field name="state">disabled</field>
        </record>
    </data>

</odoo>
