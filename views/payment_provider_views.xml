<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Inherit the payment provider form to expose mpesa_config_id -->
    <record id="view_payment_provider_form_mpesa" model="ir.ui.view">
        <field name="name">payment.provider.form.mpesa</field>
        <field name="model">payment.provider</field>
        <field name="inherit_id" ref="payment.view_payment_provider_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='provider_specific_fields']" position="inside">
                <group invisible="code != 'mpesa_daraja'">
                    <field name="mpesa_config_id"
                           required="code == 'mpesa_daraja'"
                           domain="[('company_id', '=', company_id)]"/>
                </group>
            </xpath>
        </field>
    </record>

</odoo>
